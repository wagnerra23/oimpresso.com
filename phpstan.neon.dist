includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    # Nível 5 inicial (ADR 0208) — sobe pra 6→7 incremental após baseline limpa em 90d.
    # Estatística Larastan: nível 5 captura 80% dos bugs typing (undefined methods,
    # type mismatch params, null pointer). Níveis 6-7 entram em refinamentos
    # (generic Collection, strict comparison).
    level: 5

    paths:
        - app
        - Modules

    # Excluir paths que não devem ser analisados.
    # `(?)` marca como opcional — não falha se path não existir no worktree.
    excludePaths:
        - vendor (?)
        - storage (?)
        - bootstrap/cache (?)
        - public (?)
        - node_modules (?)
        # Migrations: schema raw, baixo valor PHPStan
        - app/Database/Migrations/* (?)
        - Modules/*/Database/Migrations/* (?)
        # Tests: rodam via Pest, lint próprio
        - tests/* (?)
        - Modules/*/Tests/* (?)
        # Console Commands: Larastan 3.10 internal error "option env already exists"
        # ao processar Symfony Command signatures (bug upstream conhecido com PHP 8.4 +
        # Laravel 13). Re-incluir quando upstream fix landar.
        # Issue tracking: https://github.com/larastan/larastan/issues (filtrar 8.4 + L13)
        - app/Console/Commands/* (?)
        - Modules/*/Console/* (?)

        # === 14 erros "non-ignorable" pre-existentes (PHPStan recusa ignoreErrors) ===
        # 5x return.missing: scaffold controllers stubs sem `return back();` no fim
        # Owner módulo adiciona em PR docs/<modulo>-* — débito documentado ADR 0208.
        - Modules/Financeiro/Http/Controllers/FinanceiroController.php (?)
        - Modules/NfeBrasil/Http/Controllers/NfeBrasilController.php (?)
        - Modules/RecurringBilling/Http/Controllers/RecurringBillingController.php (?)
        # 9x class.notFound: Officeimpresso/Transformers/* usam Resource (Laravel 5)
        # em vez de JsonResource (5.6+). Owner Officeimpresso migra em PR dedicado.
        - Modules/Officeimpresso/Transformers/* (?)

    # Ignore patterns canônicos pra UltimatePOS legacy
    ignoreErrors:
        # Session UPOS canon: `session('user.business_id')` vs Auth::user()->business_id
        # Pattern existente em 1000+ controllers, baseline absorve gradualmente.
        - identifier: argument.type
          message: '#Parameter \#1 \$key of function session expects string\|null#'

        # nullsafe.neverNull: Larastan no Linux detecta `?->business_id` quando model
        # marcado non-nullable em DocBlock. Local Windows não detecta (diff de stub).
        # Suprime globalmente até harmonizar — débito Onda 2.4 (PR futuro).
        - identifier: nullsafe.neverNull

        # Diff Win↔Linux Larastan stubs — mesma família do nullsafe.neverNull.
        # Detectados só no CI Linux (PR #1868 NoNopMutationController) em código
        # pré-existente NÃO tocado por este PR. Suprime globalmente — débito de
        # cleanup gradual nos módulos owners (Onda 3+).
        - identifier: booleanOr.alwaysFalse
        - identifier: equal.alwaysFalse
        - identifier: identical.alwaysFalse

        # === 14 erros pre-existentes "non-ignorable" (não cabem em baseline.neon)
        #     Cada um é débito documentado pra fix em PR per módulo:
        #     - return.missing (5): scaffold controllers vazios — owner módulo adiciona `return back();`
        #     - class.notFound (9): Officeimpresso/Transformers/* usam Resource (Laravel 5) em vez de JsonResource — owner Officeimpresso migra
        # ===

        # 5x return.missing — scaffold controllers vazios
        - identifier: return.missing
          path: Modules/Financeiro/Http/Controllers/FinanceiroController.php
        - identifier: return.missing
          path: Modules/NfeBrasil/Http/Controllers/NfeBrasilController.php
        - identifier: return.missing
          path: Modules/RecurringBilling/Http/Controllers/RecurringBillingController.php

        # 9x class.notFound — Officeimpresso Transformers usam classe legacy Resource (Laravel 5)
        # Fix: rename `Resource` → `JsonResource` (Laravel 5.6+).
        # Issue tracking: owner Officeimpresso (Wagner) migra em PR docs/officeimpresso-*
        - identifier: class.notFound
          path: Modules/Officeimpresso/Transformers/*.php
          message: '#unknown class Illuminate.Http.Resources.Json.Resource#'

        # 2x trait.unused FALSO-POSITIVO (NÃO é débito — não baseline).
        # PersistsDriftAlert + PublishesDriftToCentrifugo SÃO usados por
        # Modules/Governance/Console/Commands/GovernanceAuditCommand (use nas linhas
        # 44-45; chamados em 165 persistirDriftAlert + 171 publishDriftToCentrifugo).
        # Esse command é o orchestrator do `governance:audit` (ADR 0216), agendado em
        # app/Console/Kernel.php (daily 06:35 BRT). Mas Console/* está em excludePaths
        # (larastan 3.10 bug PHP 8.4 — ver acima), então PHPStan não enxerga o
        # consumidor e reporta o trait como "usado zero vezes". Remover os traits
        # quebraria o command em prod. Ignore pontual por identifier+path.
        - identifier: trait.unused
          path: Modules/Governance/Services/Concerns/PersistsDriftAlert.php
        - identifier: trait.unused
          path: Modules/Governance/Services/Concerns/PublishesDriftToCentrifugo.php

    # Reporta erros do baseline (não ignora)
    reportUnmatchedIgnoredErrors: false

    # Cache PHPStan no GitHub Actions cache (também usado local).
    # Nota PHPStan 2.x: `checkMissingIterableValueType` e
    # `checkGenericClassInNonGenericObjectType` foram REMOVIDAS — agora cobertas
    # automaticamente pelos níveis (level 6+ verifica generic types).
    tmpDir: .phpstan-cache

# Custom rules oimpresso (ADR 0212 Camada 3, US-INFRA-020+)
services:
    -
        class: App\PhpStan\Rules\NoSilentFallbackRule
        tags:
            - phpstan.rules.rule
    -
        # ADR 0208 + ADR 0093 (Tier 0 multi-tenant). US-INFRA-017.
        # Detecta Module Controllers fazendo Eloquent query sem business_id mention.
        class: App\PhpStan\Rules\NoMissingTenantScopeRule
        tags:
            - phpstan.rules.rule
    -
        # ADR 0208 + T-AP-13 LICOES_F3. US-INFRA-019.
        # Detecta methods públicos em Controllers retornando APENAS back()/redirect()
        # sem mutação — endpoint vira API de mentirinha.
        class: App\PhpStan\Rules\NoNopMutationControllerRule
        tags:
            - phpstan.rules.rule

