{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oimpresso.com/schemas/adr-frontmatter.schema.json",
  "title": "ADR frontmatter — oimpresso",
  "description": "Schema canônico do bloco YAML de frontmatter em memory/decisions/*.md. Ver _SCHEMA.md.",
  "type": "object",
  "required": [
    "slug",
    "number",
    "title",
    "type",
    "status",
    "authority",
    "lifecycle",
    "decided_by",
    "decided_at"
  ],
  "additionalProperties": true,
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[0-9]{4}-[a-z0-9-]+$",
      "description": "Bate com o nome do arquivo sem .md, ex: 0053-mcp-server-governanca-como-produto"
    },
    "number": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9999,
      "description": "Prefixo numérico do filename — ex 0053 → 53"
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 250
    },
    "type": {
      "type": "string",
      "const": "adr"
    },
    "status": {
      "type": "string",
      "enum": ["rascunho", "proposto", "aceito", "deprecated", "superseded"]
    },
    "authority": {
      "type": "string",
      "enum": ["canonical", "reference", "exploratory"]
    },
    "lifecycle": {
      "type": "string",
      "enum": ["ativo", "arquivado", "substituido"]
    },
    "decided_by": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["W", "F", "M", "L", "E"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "decided_at": {
      "type": "string",
      "format": "date",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "module": {
      "type": ["string", "null"],
      "enum": [
        "copiloto",
        "financeiro",
        "pontowr2",
        "memcofre",
        "cms",
        "officeimpresso",
        "connector",
        "grow",
        "core",
        "infra",
        null
      ]
    },
    "quarter": {
      "type": "string",
      "pattern": "^[0-9]{4}-Q[1-4]$"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "supersedes": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[0-9]{4}-[a-z0-9-]+$" },
      "uniqueItems": true,
      "default": []
    },
    "supersedes_partially": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[0-9]{4}-[a-z0-9-]+$" },
      "uniqueItems": true,
      "default": []
    },
    "superseded_by": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[0-9]{4}-[a-z0-9-]+$" },
      "uniqueItems": true,
      "default": []
    },
    "related": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[0-9]{4}-[a-z0-9-]+$" },
      "uniqueItems": true,
      "default": []
    },
    "cites": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "pii": {
      "type": "boolean",
      "default": false
    },
    "review_triggers": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "scope_required": {
      "type": ["string", "null"],
      "default": null
    },
    "admin_only": {
      "type": "boolean",
      "default": false
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "superseded" } } },
      "then": {
        "required": ["superseded_by"],
        "properties": {
          "superseded_by": { "minItems": 1 },
          "lifecycle": { "const": "substituido" }
        }
      }
    }
  ]
}
