{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "startServerCommand": "APP_URL=http://127.0.0.1:8091 php artisan serve --host=127.0.0.1 --port=8091 --no-reload",
      "startServerReadyPattern": "Server running",
      "startServerReadyTimeout": 90000,
      "url": [
        "http://127.0.0.1:8091/_visreg-login/1?to=/financeiro/unificado",
        "http://127.0.0.1:8091/_visreg-login/1?to=/sells"
      ],
      "settings": {
        "preset": "desktop",
        "onlyCategories": ["performance"],
        "chromeFlags": "--no-sandbox",
        "maxWaitForLoad": 60000
      }
    },
    "assert": {
      "aggregationMethod": "median",
      "assertions": {
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 4000 }],
        "total-blocking-time": ["error", { "maxNumericValue": 600 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
