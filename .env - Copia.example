DEEPSEEK_API_KEY=
# OPENAI_API_KEY ja existe acima — usado tambem por evolution:* pra vision/structured (gpt-4o)
# XAI_API_KEY: gere em https://console.x.ai/team (Grok — contexto realtime/X)
