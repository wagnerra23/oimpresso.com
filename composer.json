{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.1",
        "aloha/twilio": "^4.0",
        "automattic/woocommerce": "^3.0",
        "barryvdh/laravel-dompdf": "^3.0",
        "composer/semver": "^3.4",
        "consoletvs/charts": "^6.5",
        "eduardokum/laravel-boleto": "^0.11.0",
        "giggsey/libphonenumber-for-php": "^8.12",
        "growthbook/growthbook": "^2.0",
        "guzzlehttp/guzzle": "^7.2",
        "inertiajs/inertia-laravel": "^3.0",
        "laravel/ai": "^0.6.3",
        "laravel/framework": "^13.0",
        "laravel/horizon": "^5.46",
        "laravel/legacy-factories": "^1.4",
        "laravel/mcp": "^0.7.0",
        "laravel/octane": "^2.15",
        "laravel/pail": "^1.2",
        "laravel/passport": "^13.0",
        "laravel/reverb": "^1.10",
        "laravel/scout": "^11.1",
        "laravel/telescope": "^5.20",
        "laravel/tinker": "^3.0",
        "laravel/ui": "^4.2",
        "laravel/wayfinder": "^0.1.20",
        "league/flysystem-aws-s3-v3": "^3.0",
        "maatwebsite/excel": "^3.1.8",
        "meilisearch/meilisearch-php": "^1.16",
        "milon/barcode": "^13.1",
        "mpdf/mpdf": "^8.1",
        "myfatoorah/laravel-package": "^2.2",
        "nfephp-org/sped-da": "^1.1",
        "nfephp-org/sped-nfe": "dev-master#e075ec47f261e13db695f514174c01d8fb7934fc",
        "nwidart/laravel-modules": "^10.0",
        "razorpay/razorpay": "2.*",
        "sentry/sentry-laravel": "^4.25",
        "spatie/flysystem-dropbox": "^2.0",
        "spatie/laravel-activitylog": "^4.8",
        "spatie/laravel-backup": "^10.0",
        "spatie/laravel-html": "^3.13",
        "spatie/laravel-permission": "^6.0",
        "spatie/laravel-signal-aware-command": "^2.1",
        "srmklive/paypal": "^3.0",
        "stripe/stripe-php": "^7.122",
        "tightenco/ziggy": "^2.5",
        "yajra/laravel-datatables-oracle": "^13.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "knuckleswtf/scribe": "^5.0",
        "larastan/larastan": "3.10",
        "laravel/boost": "^2.4",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.5",
        "open-telemetry/exporter-otlp": "^1.0",
        "open-telemetry/opentelemetry-auto-laravel": "^1.0",
        "open-telemetry/sdk": "^1.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-browser": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpunit/phpunit": "^12.0",
        "spatie/laravel-ignition": "^2.0"
    },
    
    "autoload": {
        "files": [
            "app/Http/helpers.php"
        ],
        "classmap": [
            "database"
        ],
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "Modules/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        },
        "files": [
            "Modules/KB/Tests/Helpers.php"
        ]
    },
    "scripts": {
        "phpstan": [
            "vendor/bin/phpstan analyse --memory-limit=2G"
        ],
        "post-root-package-install": [
            "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "php artisan key:generate"
        ],
        "post-install-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postInstall"
        ],
        "post-update-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "module-grades-check": "php artisan module:grade --all --json"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "audit": {
            "ignore": [
                "PKSA-8qx3-n5y5-vvnd",
                "PKSA-w7xr-vk7n-rstm",
                "PKSA-q46n-4fdk-zjr4",
                "PKSA-qzrn-rnz3-85w1",
                "PKSA-njrm-6dtg-m2pc"
            ]
        },
        "allow-plugins": {
            "ocramius/package-versions": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/horizon"
            ]
        }
    },
    "suggest": {
        "spatie/browsershot": "Necessário pra PDF server-side do Transcript de venda (Sells/Index Onda 4 R4 C1). Requer Chrome headless instalado no runtime — funciona em CT 100 Proxmox, NÃO suportado em Hostinger shared (fallback 503 graceful)."
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "lib-custom/laravel-boleto",
            "options": {
                "symlink": false
            }
        }
    ]
}
