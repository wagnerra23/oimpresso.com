{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.1",
        "aloha/twilio": "^4.0",
        "arcanedev/log-viewer": "^10.0",
        "automattic/woocommerce": "^3.0",
        "barryvdh/laravel-dompdf": "^2.2",
        "composer/semver": "^3.0",
        "consoletvs/charts": "^6.5",
        "giggsey/libphonenumber-for-php": "^8.12",
        "guzzlehttp/guzzle": "^7.2",
        "inertiajs/inertia-laravel": "^1.3",
        "knox/pesapal": "1.5",
        "laravel/framework": "^10.0",
        "laravel/legacy-factories": "^1.4",
        "laravel/passport": "^12.0",
        "laravel/scout": "^11.1",
        "laravel/tinker": "^2.7",
        "laravel/ui": "^4.2",
        "laravelcollective/html": "^6.3",
        "league/flysystem-aws-s3-v3": "^3.0",
        "maatwebsite/excel": "^3.1.8",
        "meilisearch/meilisearch-php": "^1.16",
        "milon/barcode": "^10.0",
        "mpdf/mpdf": "^8.1",
        "myfatoorah/laravel-package": "^2.2",
        "nwidart/laravel-modules": "^10.0",
        "openai-php/laravel": "^0.4.1",
        "pusher/pusher-php-server": "^5.0",
        "razorpay/razorpay": "2.*",
        "sentry/sentry-laravel": "^4.25",
        "spatie/flysystem-dropbox": "^2.0",
        "spatie/laravel-activitylog": "^4.8",
        "spatie/laravel-backup": "^8.5",
        "spatie/laravel-html": "^3.13",
        "spatie/laravel-permission": "^6.0",
        "srmklive/paypal": "^3.0",
        "stripe/stripe-php": "^7.122",
        "yajra/laravel-datatables-oracle": "^10.11"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.6",
        "fakerphp/faker": "^1.9.1",
        "knuckleswtf/scribe": "^4.14",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.0",
        "pestphp/pest": "^2.34",
        "pestphp/pest-plugin-laravel": "^2.3",
        "phpunit/phpunit": "^10.0",
        "spatie/laravel-ignition": "^2.0"
    },
    
    "autoload": {
        "files": [
            "app/Http/helpers.php"
        ],
        "classmap": [
            "database"
        ],
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "Modules/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "php artisan key:generate"
        ],
        "post-install-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postInstall"
        ],
        "post-update-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "ocramius/package-versions": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
