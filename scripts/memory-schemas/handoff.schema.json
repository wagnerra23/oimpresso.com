{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oimpresso.com/schemas/handoff.schema.json",
  "title": "Handoff append-only frontmatter — oimpresso (ONDA 5 S1)",
  "description": "Schema canônico do bloco YAML em memory/handoffs/YYYY-MM-DD-HHMM-<slug>.md. Append-only (ADR 0130). ONDA-5-DOSSIER §5 S1.",
  "type": "object",
  "required": ["date", "slug", "tldr"],
  "additionalProperties": true,
  "properties": {
    "date": {
      "type": "string",
      "format": "date",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "time": {
      "type": "string",
      "pattern": "^[0-9]{2}:?[0-9]{2}( BRT| UTC)?$",
      "description": "HHMM ou HH:MM"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "minLength": 3,
      "maxLength": 80
    },
    "tldr": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "Resumo 1-2 linhas — primeiro item a ler quando retoma trabalho"
    },
    "decided_by": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["W", "F", "M", "L", "E"]
      },
      "uniqueItems": true
    },
    "cycle": {
      "type": ["string", "null"],
      "pattern": "^CYCLE-[0-9]{2,4}$"
    },
    "prs": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 },
      "uniqueItems": true,
      "default": []
    },
    "us": {
      "type": "array",
      "items": { "type": "string", "pattern": "^US-[A-Z]{2,8}-[0-9]{3,4}$" },
      "uniqueItems": true,
      "default": []
    },
    "next_steps": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "related_adrs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[0-9]{4}-[a-z0-9-]+$" },
      "uniqueItems": true,
      "default": []
    }
  }
}
