{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oimpresso.com/schemas/spec.schema.json",
  "title": "SPEC.md frontmatter — oimpresso (ONDA 5 S1)",
  "description": "Schema canônico do bloco YAML em memory/requisitos/<Mod>/SPEC.md. ONDA-5-DOSSIER §5 S1 — required minimalista (module, version, last_updated) pra reduzir fricção grace period 14d.",
  "type": "object",
  "required": ["module", "version", "last_updated"],
  "additionalProperties": true,
  "properties": {
    "module": {
      "type": "string",
      "description": "Nome do módulo (PascalCase ex Jana / Financeiro / NfeBrasil).",
      "minLength": 2,
      "maxLength": 80
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$",
      "description": "SemVer ex 1.0 ou 1.2.3"
    },
    "status": {
      "type": "string",
      "enum": ["rascunho", "ativo", "arquivado", "historical"]
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["W", "F", "M", "L", "E"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "last_updated": {
      "type": "string",
      "format": "date",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "us_count": {
      "type": "integer",
      "minimum": 0
    },
    "us_list": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^US-[A-Z]{2,8}-[0-9]{3,4}$"
      },
      "uniqueItems": true,
      "default": []
    },
    "related_adrs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[0-9]{4}-[a-z0-9-]+$" },
      "uniqueItems": true,
      "default": []
    }
  }
}
