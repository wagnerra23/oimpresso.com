{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oimpresso.com/schemas/adr.schema.json",
  "title": "ADR Nygard frontmatter — oimpresso (ONDA 5 S1)",
  "description": "Schema canônico do bloco YAML em memory/decisions/*.md. Espelha memory/decisions/_schema.json (fonte legada) + ONDA-5-DOSSIER §5 S1 (campos extras supersedes/superseded_by/related opcionais).",
  "type": "object",
  "required": [
    "slug",
    "number",
    "title",
    "type",
    "status",
    "authority",
    "lifecycle",
    "decided_by",
    "decided_at"
  ],
  "additionalProperties": true,
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[0-9]{4}-[a-z0-9-]+$",
      "description": "Bate com o nome do arquivo sem .md, ex: 0053-mcp-server-governanca-como-produto"
    },
    "number": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9999
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 250
    },
    "type": {
      "type": "string",
      "const": "adr"
    },
    "status": {
      "type": "string",
      "enum": ["rascunho", "proposto", "aceito", "deprecated", "superseded"]
    },
    "authority": {
      "type": "string",
      "enum": ["canonical", "reference", "exploratory"]
    },
    "lifecycle": {
      "type": "string",
      "enum": ["ativo", "arquivado", "substituido", "historical"]
    },
    "decided_by": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["W", "F", "M", "L", "E"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "decided_at": {
      "type": "string",
      "format": "date",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "module": {
      "type": ["string", "null"]
    },
    "supersedes": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[0-9]{4}-[a-z0-9-]+$" },
      "uniqueItems": true,
      "default": []
    },
    "superseded_by": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[0-9]{4}-[a-z0-9-]+$" },
      "uniqueItems": true,
      "default": []
    },
    "related": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[0-9]{4}-[a-z0-9-]+$" },
      "uniqueItems": true,
      "default": []
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "superseded" } }, "required": ["status"] },
      "then": {
        "required": ["superseded_by"],
        "properties": {
          "superseded_by": { "minItems": 1 },
          "lifecycle": { "enum": ["substituido", "arquivado"] }
        }
      }
    }
  ]
}
