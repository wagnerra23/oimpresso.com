{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oimpresso.com/schemas/topico.schema.json",
  "title": "Tópico canônico de módulo — oimpresso",
  "description": "Contrato forward-only para memory/requisitos/<Modulo>/topicos/<id>.md. O BRIEFING aponta para tópicos; não recopia o conteúdo. O schema valida identidade, âncoras e estado de revisão. A prosa continua sujeita a revisão humana.",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "module", "title", "kind", "status", "updated_at", "review"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "module": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 180
    },
    "kind": {
      "type": "string",
      "enum": ["capacidade", "regra-negocio", "fluxo", "integracao", "risco", "tela", "decisao"]
    },
    "status": {
      "type": "string",
      "enum": ["rascunho", "ativo", "contestado", "deprecated"]
    },
    "updated_at": {
      "type": "string",
      "format": "date",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "valid_from": {
      "type": "string",
      "format": "date",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "Bi-temporal (modelo Zep) — tempo-de-DOMÍNIO: desde quando o fato deste tópico é verdadeiro no mundo (≠ updated_at, que é tempo-de-transação, quando o doc foi escrito). Data histórica: não apodrece (append-only). Ancore num evento verificável (incidente/fix/ADR); para comportamento legado de origem desconhecida, omita ou use a data de observação com nota."
    },
    "valid_until": {
      "type": "string",
      "format": "date",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "Bi-temporal (modelo Zep) — tempo-de-DOMÍNIO: quando o fato deste tópico DEIXOU de ser verdadeiro. Presença = comportamento superado; o leitor (recall/brief) trata valid_until no passado como superado, mas SÓ quando a âncora resolve (advisory, não presence-gate). NÃO pode ser data solta escrita à mão — dependentSchemas exige superseded_by_adr OU superseded_by_topic (fato verificável, proibicoes.md §5). Idealmente = decided_at do ADR supersessor."
    },
    "superseded_by_adr": {
      "type": "string",
      "pattern": "^[0-9]{4}-[A-Za-z0-9.-]+$",
      "description": "Âncora verificável do valid_until: slug do ADR supersessor que invalidou o fato (o arquivo memory/decisions/<slug>.md deve existir). A data de valid_until deve espelhar o decided_at desse ADR — nunca uma data inventada."
    },
    "superseded_by_topic": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Âncora verificável do valid_until: id do tópico sucessor que substituiu este (o arquivo memory/requisitos/<Modulo>/topicos/<id>.md deve existir)."
    },
    "anchors": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "screens": { "$ref": "#/definitions/pathList" },
        "routes": { "$ref": "#/definitions/pathList" },
        "controllers": { "$ref": "#/definitions/pathList" },
        "functions": { "$ref": "#/definitions/pathList" },
        "models": { "$ref": "#/definitions/pathList" },
        "tables": { "$ref": "#/definitions/stringList" },
        "tests": { "$ref": "#/definitions/pathList" },
        "adrs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[0-9]{4}-[A-Za-z0-9.-]+$" },
          "uniqueItems": true
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": true,
      "required": ["state", "verdict", "confidence"],
      "properties": {
        "state": {
          "type": "string",
          "enum": ["proposto", "revisado-central", "aprovado-humano", "rejeitado"]
        },
        "verdict": {
          "type": "string",
          "enum": ["concordo", "discordo", "incerto", "nao-se-aplica"]
        },
        "confidence": {
          "type": "string",
          "enum": ["baixa", "media", "alta"]
        },
        "central_reviewer": { "type": ["string", "null"] },
        "human_approver": { "type": ["string", "null"] }
      }
    },
    "critiques": {
      "type": "array",
      "description": "Pareceres independentes preservados antes da síntese central. Divergência não é apagada.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["critic", "at", "verdict", "summary", "evidence"],
        "properties": {
          "critic": { "type": "string", "minLength": 2 },
          "at": { "type": "string", "format": "date", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
          "verdict": { "type": "string", "enum": ["concordo", "discordo", "incerto", "nao-se-aplica"] },
          "summary": { "type": "string", "minLength": 8 },
          "evidence": { "$ref": "#/definitions/evidenceList" }
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "status", "text", "evidence"],
        "properties": {
          "id": { "type": "string", "pattern": "^C[0-9]{2,}$" },
          "status": {
            "type": "string",
            "enum": ["observado", "inferido", "proposto", "aceito", "rejeitado", "incerto"]
          },
          "text": { "type": "string", "minLength": 8 },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "ref"],
              "properties": {
                "type": { "type": "string", "enum": ["codigo", "teste", "runtime", "adr", "dono", "externa"] },
                "ref": { "type": "string", "minLength": 3 },
                "note": { "type": "string" }
              }
            }
          }
        }
      }
    }
  },
  "dependentSchemas": {
    "valid_until": {
      "description": "§5 proibicoes.md: expiração ancora num fato verificável, nunca data solta que apodrece. Se valid_until existe, o tópico DEVE nomear o que o superou (ADR supersessor ou tópico sucessor). A existência real da âncora é verificada pelo leitor/fact-anchor — o schema só garante que a expiração carrega seu motivo.",
      "anyOf": [
        { "required": ["superseded_by_adr"] },
        { "required": ["superseded_by_topic"] }
      ]
    }
  },
  "dependentRequired": {
    "superseded_by_adr": ["valid_until"],
    "superseded_by_topic": ["valid_until"]
  },
  "definitions": {
    "evidenceList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "ref"],
        "properties": {
          "type": { "type": "string", "enum": ["codigo", "teste", "runtime", "adr", "dono", "externa"] },
          "ref": { "type": "string", "minLength": 3 },
          "note": { "type": "string" }
        }
      }
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "pathList": {
      "type": "array",
      "items": { "type": "string", "minLength": 3, "pattern": "^[^\\\\]+$" },
      "uniqueItems": true
    }
  }
}
