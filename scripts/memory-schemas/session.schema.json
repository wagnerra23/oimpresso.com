{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oimpresso.com/schemas/session.schema.json",
  "title": "Session log frontmatter — oimpresso (ONDA 5 S1)",
  "description": "Schema canônico do bloco YAML em memory/sessions/YYYY-MM-DD-*.md. ONDA-5-DOSSIER §5 S1 — required minimalista (date, topic) pra grace period 14d (legacy sessions sem frontmatter).",
  "type": "object",
  "required": ["date", "topic"],
  "additionalProperties": true,
  "properties": {
    "date": {
      "type": "string",
      "format": "date",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "hour": {
      "type": "string",
      "pattern": "^[0-9]{2}:[0-9]{2}( BRT| UTC)?$"
    },
    "duration": {
      "type": "string",
      "pattern": "^[0-9]+(\\.[0-9]+)?h$",
      "description": "Duração ex 2.5h"
    },
    "topic": {
      "type": "string",
      "minLength": 5,
      "maxLength": 250
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["W", "F", "M", "L", "E", "C"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "outcomes": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "prs": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 },
      "uniqueItems": true,
      "default": []
    },
    "us": {
      "type": "array",
      "items": { "type": "string", "pattern": "^US-[A-Z]{2,8}-[0-9]{3,4}$" },
      "uniqueItems": true,
      "default": []
    },
    "related_adrs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[0-9]{4}-[a-z0-9-]+$" },
      "uniqueItems": true,
      "default": []
    }
  }
}
