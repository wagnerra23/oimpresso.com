# URL do endpoint ADS (local Herd ou produção)
ADS_API_URL=http://oimpresso.test/api/ads/route
ADS_HEALTH_URL=http://oimpresso.test/api/ads/health

# Token Bearer — mesmo valor de ADS_API_KEY no .env do Laravel
ADS_API_KEY=

# Business ID padrão para eventos (1 = oimpresso, 4 = ROTA LIVRE)
DEFAULT_BUSINESS_ID=1

# LOCAL_MODE=true → usa watchers v1 (filesystem); requer REPO_PATH e LARAVEL_LOG_PATH
# LOCAL_MODE=false (default) → watchers v2 HTTP poll (CT 100 → Hostinger via ADS_API_URL)
LOCAL_MODE=false

# Usados apenas se LOCAL_MODE=true
REPO_PATH=D:/oimpresso.com
LARAVEL_LOG_PATH=D:/oimpresso.com/storage/logs/laravel.log

# Intervalo de poll dos watchers (ms)
GIT_POLL_INTERVAL_MS=30000
LOG_POLL_INTERVAL_MS=5000

# Logging
LOG_LEVEL=info

# Ollama opcional (substitui triage rule-based por LLM local)
# Comente as 2 linhas abaixo para usar fallback regex
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-coder:14b

# Aceitar TLS self-signed (true em dev local com Herd, false em produção)
ALLOW_INSECURE_TLS=true
