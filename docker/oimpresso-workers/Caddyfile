# FrankenPHP Caddy config pro oimpresso-workers
# Ports: 80 (Traefik HTTP→HTTPS handles TLS upstream)

{
    auto_https off  # Traefik faz TLS upstream
    admin off
    log {
        output stdout
        format console
        level INFO
    }
    frankenphp {
        num_threads 8
    }
}

:80 {
    root * /app/public
    php_server
    encode gzip zstd

    # Rotas só de workers (resto retorna 404)
    @workers_only {
        path /api/cc/ingest /api/cc/health /api/health /api/eval/* /api/metrics/*
    }
    handle @workers_only {
        php_server
    }
    handle {
        respond "oimpresso-workers — endpoint não disponível neste host. Use oimpresso.com." 404
    }

    log {
        output stdout
        format json
    }
}
