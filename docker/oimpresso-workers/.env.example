# oimpresso-workers .env — copia pra .env e preenche
# Source-of-truth dos secrets: Vaultwarden (vault.oimpresso.com)

APP_NAME=oimpresso-workers
APP_ENV=production
APP_KEY=                              # base64:... (mesmo do Hostinger pra session compat)
APP_DEBUG=false
APP_URL=https://workers.oimpresso.com

# MySQL Hostinger compartilhado (mesma source-of-truth do app principal)
DB_CONNECTION=mysql
DB_HOST=148.135.133.115                # IP público Hostinger MySQL (whitelist o 177.74.67.30)
DB_PORT=3306
DB_DATABASE=u906587222_oimpresso
DB_USERNAME=u906587222_oimpresso
DB_PASSWORD=                          # do .env Hostinger

# Redis local CT 100
REDIS_HOST=oimpresso-workers-redis
REDIS_PORT=6379
QUEUE_CONNECTION=redis
CACHE_DRIVER=redis
SESSION_DRIVER=redis

# Logs concisos
LOG_CHANNEL=stack
LOG_LEVEL=info

# OpenAI (LLM principal continua externo)
OPENAI_API_KEY=                       # mesmo do Hostinger
COPILOTO_AI_DRY_RUN=false
COPILOTO_AI_ADAPTER=auto

# Meilisearch (já no CT 100)
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch-oimpresso:7700
MEILISEARCH_KEY=

# OLLAMA EMBEDDER LOCAL (NOVO — Cycle 02 ADR 0060)
OLLAMA_EMBED_URL=http://192.168.0.50:11434/api/embeddings
OLLAMA_EMBED_MODEL=nomic-embed-text
COPILOTO_EMBEDDER_DRIVER=local        # 'openai' (default fallback) | 'local' (ollama)

# MCP server URL (CT 100)
MCP_SERVER_URL=https://mcp.oimpresso.com/api/mcp

# Sentry (opcional)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
