# MEM-MCP-1.b (ADR 0053) — Variáveis do container oimpresso-mcp
#
# Copiar para .env e preencher (NÃO commitar — está no .gitignore).
# Compartilha credenciais críticas com app principal Hostinger:
#   APP_KEY (mesma — pra Sanctum tokens funcionarem em ambos)
#   DB_DATABASE / DB_USERNAME / DB_PASSWORD (mesmas — DB compartilhado)

APP_NAME=oimpresso-mcp
APP_ENV=production
APP_KEY=base64:COPIAR_DO_HOSTINGER_ENV
APP_DEBUG=false
APP_URL=https://mcp.oimpresso.com

# DB direto MySQL Hostinger (Remote MySQL whitelist 177.74.67.30 no hPanel)
# DB_HOST=148.135.133.115 já é setado pelo docker-compose.yml
DB_CONNECTION=mysql
DB_HOST=148.135.133.115
DB_PORT=3306
DB_DATABASE=u906587222_oimpresso
DB_USERNAME=u906587222_oimpresso
DB_PASSWORD=COPIAR_DO_HOSTINGER_ENV

# Logs vão pra stderr (Docker captura)
LOG_CHANNEL=errorlog

# Sanctum (compartilhado com app principal)
SANCTUM_STATEFUL_DOMAINS=mcp.oimpresso.com,oimpresso.com
SESSION_DOMAIN=.oimpresso.com

# Cache local Redis opcional (futuro Dia 4)
CACHE_DRIVER=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync

# MCP-specific
COPILOTO_MCP_SYNC_TOKEN=GERAR_VIA_OPENSSL_RAND_HEX_32
COPILOTO_MCP_AUDIT_RETENTION_DAYS=365
