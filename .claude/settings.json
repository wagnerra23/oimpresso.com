{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Write(memory/handoffs/**)",
      "Write(memory/sessions/**)",
      "Edit(memory/08-handoff.md)",
      "Bash(git add:*)",
      "PowerShell(git add:*)",
      "Bash(git commit:*)",
      "PowerShell(git commit:*)",
      "Bash(git push:*)",
      "PowerShell(git push:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/brief-fetch-curl.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/handoff-inline.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/check-skills-fresh.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/tier-a-banner.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/loop-fechar-check.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/licoes-code-two-strikes.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/git-base-freshness-guard.mjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill|DesignSync|design-login",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/diag-pretooluse-trace.mjs"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-askq-execution-menu.mjs"
          }
        ]
      },
      {
        "matcher": "Read|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-ancora-no-olho.mjs"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-automem.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/block-brl-values-in-memory.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/block-memory-drift.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/block-mwart-violation.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/charter-validate.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/modulo-preflight-warning.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/preflight-new-capability.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/block-bom-encoding.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/block-merge-markers.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/block-routes-string-legacy.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/nudge-test-contract-anchor.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/warn-red-first.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/block-test-without-red.mjs"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-destructive.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/pii-redactor.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/commit-discipline-check.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/block-claim-without-evidence.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/post-merge-ui-smoke-required.mjs"
          }
        ]
      },
      {
        "matcher": "mcp__computer-use__screenshot|mcp__[Cc]laude[-_][Ii]n[-_][Cc]hrome__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-merge-ui-smoke-required.mjs"
          }
        ]
      },
      {
        "matcher": "mcp__.*figma.*|mcp__.*__(use_figma|get_design_context|get_figjam|get_variable_defs|search_design_system|get_libraries|get_context_for_code_connect|get_code_connect_map|get_code_connect_suggestions|add_code_connect_map|send_code_connect_mappings|get_screenshot|get_metadata|download_assets|upload_assets|create_new_file|generate_diagram)",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-figma-without-optin.mjs"
          }
        ]
      },
      {
        "matcher": "DesignSync",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-design-sync-without-optin.mjs"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-skill-design-sync-without-optin.mjs"
          }
        ]
      },
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-test-fora-ct100.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-merge-ui-smoke-required.mjs"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/audit-creates-tasks.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/memory-pending.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/nudge-recommend-not-menu.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/nudge-diagnosis-without-evidence.mjs"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/force-r12-closing-signal.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/design-handoff-reprocess.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/block-figma-without-optin.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/block-design-sync-without-optin.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/design-compare-protocol.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/design-agente-ativa.mjs"
          }
        ]
      }
    ]
  }
}