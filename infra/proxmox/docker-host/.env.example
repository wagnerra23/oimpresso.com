# Stack docker-host CT 100 — copiar pra .env e preencher
#
# .env NÃO entra no git (gitignored). Wagner mantém o .env real no CT em
# /opt/docker-host/.env

# E-mail do dono da empresa pra Let's Encrypt (avisos de expiração)
ACME_EMAIL=wagnerra@gmail.com

# Basic auth pro dashboard Traefik. Gerar com:
#   docker run --rm httpd:2.4-alpine htpasswd -nbB admin SUA_SENHA
# Cole o resultado completo (formato user:$2y$05$hash...). Escapar $ no compose:
# trocar cada $ por $$ na env do compose.
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$replace-this-with-real-bcrypt-hash

# === Meilisearch (memória semântica Copiloto — meilisearch.oimpresso.com) ===
# Mesma key usada no Hostinger .env (MEILISEARCH_KEY)
MEILI_MASTER_KEY=TFLfQX3Diuz42MydPn68AYH9Km1JbaBI

# === Vaultwarden (cofre de senhas self-hosted — ADR 0044) ===
# 1ª subida: deixar true pra Wagner criar conta. Depois trocar pra false.
VAULTWARDEN_SIGNUPS_ALLOWED=true
# Token do painel admin /admin (gerar com: openssl rand -base64 48)
VAULTWARDEN_ADMIN_TOKEN=gerar-com-openssl-rand-base64-48

# === Reverb container (ADR 0042 + 0043) ===
# IMPORTANTE: REVERB_APP_LARAVEL_KEY deve ser o MESMO valor que o app
# Hostinger usa em APP_KEY (Laravel usa pra criptografar mensagens broadcast)
REVERB_APP_LARAVEL_KEY=base64:gerar-com-php-artisan-key-generate

# Credenciais do app Reverb — usar nos clientes Echo + servidor
REVERB_APP_ID=oimpresso
REVERB_APP_KEY=gerar-string-rand-20chars
REVERB_APP_SECRET=gerar-string-rand-32chars
