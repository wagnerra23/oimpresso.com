# Stack docker-host CT 100 — copiar pra .env e preencher
#
# .env NÃO entra no git (gitignored). Wagner mantém o .env real no CT em
# /opt/docker-host/.env

# E-mail do dono da empresa pra Let's Encrypt (avisos de expiração)
ACME_EMAIL=wagnerra@gmail.com

# Basic auth pro dashboard Traefik (apenas LAN). Gerar com:
#   docker run --rm httpd:2.4-alpine htpasswd -nbB admin SUA_SENHA
# Cole o resultado completo (formato user:$2y$05$hash...). Escapar $ no compose:
# trocar cada $ por $$ na env do compose.
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$replace-this-with-real-bcrypt-hash

# === Variáveis pro Reverb (a usar em PR seguinte) ===
APP_KEY=base64:gerar-com-php-artisan-key-generate
REVERB_APP_ID=oimpresso
REVERB_APP_KEY=gerar-uuid
REVERB_APP_SECRET=gerar-uuid
