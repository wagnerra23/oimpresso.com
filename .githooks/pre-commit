#!/usr/bin/env bash
# GUARDA Anti-Drift pre-commit hook
# Constituição Art. 7 — Module Charter
#
# Instalação (once-only):
#   git config core.hooksPath .githooks
#
# Funcionalidade:
#   - Detecta novos controllers staged em Modules/<X>/Http/Controllers/
#   - Verifica se filename está declarado em Modules/<X>/SCOPE.md.contains[]
#   - Se não está, AVISA (não bloqueia em modo dev)
#
# Pra modo strict (bloqueia commit):
#   export OIMPRESSO_GUARDA_STRICT=1

set -e

# Procura PHP executável (prioriza Herd no Windows).
# Nota: usar -f (existe) ao invés de -x (executable) — arquivos .bat no
# Windows Git Bash não têm bit POSIX executable mesmo rodando via cmd.exe.
PHP_BIN=""
if command -v php >/dev/null 2>&1; then
    PHP_BIN="php"
elif [ -f "$HOME/.config/herd/bin/php.bat" ]; then
    PHP_BIN="$HOME/.config/herd/bin/php.bat"
elif [ -n "$USERNAME" ] && [ -f "/c/Users/$USERNAME/.config/herd/bin/php.bat" ]; then
    PHP_BIN="/c/Users/$USERNAME/.config/herd/bin/php.bat"
elif [ -n "$USER" ] && [ -f "/c/Users/$USER/.config/herd/bin/php.bat" ]; then
    PHP_BIN="/c/Users/$USER/.config/herd/bin/php.bat"
else
    # Última tentativa: enumerar /c/Users/*/.config/herd/bin/php.bat
    for CANDIDATE in /c/Users/*/.config/herd/bin/php.bat; do
        if [ -f "$CANDIDATE" ]; then
            PHP_BIN="$CANDIDATE"
            break
        fi
    done
fi

if [ -z "$PHP_BIN" ]; then
    echo "GUARDA: php não encontrado, pulando check-scope (instale Herd ou adicione PHP ao PATH)"
    exit 0
fi

# Roda check-scope no modo --staged
STRICT_FLAG=""
if [ "${OIMPRESSO_GUARDA_STRICT:-0}" = "1" ]; then
    STRICT_FLAG="--strict"
fi

"$PHP_BIN" bin/check-scope.php --staged $STRICT_FLAG
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    if [ "${OIMPRESSO_GUARDA_STRICT:-0}" = "1" ]; then
        echo ""
        echo "GUARDA: drift detectado em modo strict — commit BLOQUEADO."
        echo "Pra forçar (último caso): git commit --no-verify"
        exit 1
    fi
fi

# ── UI Lint (Onda 2.2 AUTOMATION-ROADMAP · Constituição UI v2 · ADR UI-0013) ──
# Roda ui:lint --changed-only só se PHP disponível e baseline existe.
# Strict bloqueia em regressão. Default: warning.
if [ -f "config/ui-lint-baseline.json" ]; then
    UI_STRICT=""
    if [ "${OIMPRESSO_UI_LINT_STRICT:-0}" = "1" ]; then
        UI_STRICT="--strict"
    fi

    "$PHP_BIN" artisan ui:lint \
        --changed-only \
        --baseline=config/ui-lint-baseline.json \
        $UI_STRICT 2>/dev/null

    UI_EXIT=$?
    if [ $UI_EXIT -ne 0 ] && [ "${OIMPRESSO_UI_LINT_STRICT:-0}" = "1" ]; then
        echo ""
        echo "UI LINT: regressão UI detectada em modo strict — commit BLOQUEADO."
        echo "Use 'php artisan ui:lint --detail' pra ver detalhes."
        echo "Refs: ADR UI-0013 · UI-LINT-USAGE.md · PRE-MERGE-UI.md"
        echo "Pra forçar (último caso): git commit --no-verify"
        exit 1
    fi
fi

# ── Secrets governance (ADR 0215 Camada 5 — 2026-05-28) ──
# Roda secrets:scan --diff-only --fail-on-drift se artisan disponível.
# Bloqueia commit que adicione secret sem entry em memory/_INDEX-SECRETS.md.
# Pra emergencia: git commit --no-verify (registra exceção no PR).
if [ -f artisan ]; then
    if ! "$PHP_BIN" artisan secrets:scan --diff-only --fail-on-drift 2>/dev/null; then
        echo ""
        echo "❌ SECRETS GOVERNANCE: secret novo detectado SEM entry em memory/_INDEX-SECRETS.md"
        echo "Ações:"
        echo "  1. Adicione linha no índice canônico antes de commitar"
        echo "  2. OR padrão ponteiro: não commitar valor real, só ponteiro pra Vaultwarden/CT 100 file"
        echo "  3. Pra emergencia: git commit --no-verify (registra exceção no PR body)"
        echo "Refs: ADR 0215 · skill memory-first-secret-search"
        exit 1
    fi
fi

# ── Governance Drift Framework (ADR 0216 — 2026-05-28) ──
# Roda governance:audit --diff-only com checkers cadence=on_commit + enforcement=block.
# Bloqueia commit que viole Tier 0 (multi_tenant_scope) ou outros block-level checkers.
# Generaliza secrets:scan acima — futuro PR remove o bloco anterior depois canary 7d.
# Pra emergencia: git commit --no-verify (registra exceção no PR body).
if [ -f artisan ]; then
    GOV_STRICT_FLAG=""
    if [ "${OIMPRESSO_GOVERNANCE_STRICT:-0}" = "1" ]; then
        GOV_STRICT_FLAG="--fail-on=block"
    fi

    if ! "$PHP_BIN" artisan governance:audit --diff-only --no-persist $GOV_STRICT_FLAG 2>/dev/null; then
        echo ""
        echo "❌ GOVERNANCE FRAMEWORK: drift detectado em checker(s) block-level"
        echo "Ações:"
        echo "  1. Resolver finding apontado acima (multi-tenant scope, secrets, etc.)"
        echo "  2. OR registrar exception em config/governance-exceptions.php (com expiry + ADR ref)"
        echo "  3. Pra emergencia: git commit --no-verify"
        echo "Refs: ADR 0216 · governance:audit --check=<name>"
        exit 1
    fi
fi

exit 0
